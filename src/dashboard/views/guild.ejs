<script>
const GUILD = '<%= guild.id %>';

// ── Sidebar navigation ─────────────────────────────────────────
document.querySelectorAll('.sb-item').forEach(item => {
  item.addEventListener('click', () => {
    document.querySelectorAll('.sb-item').forEach(i => i.classList.remove('active'));
    document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
    item.classList.add('active');
    const panel = document.getElementById('panel-' + item.dataset.p);
    if (panel) panel.classList.add('active');
    // Load dynamic data panels
    const loaders = { tournaments: loadTournaments, ticketlist: loadTickets, modlogs: loadModlogs, leaderboard: loadLeaderboard, members: loadMembers };
    if (loaders[item.dataset.p]) loaders[item.dataset.p]();
  });
});

// ── Helpers ────────────────────────────────────────────────────
const val = id => document.getElementById(id)?.value || '';
const getChecked = id => document.getElementById(id)?.checked;

function showMsg(id, ok, text) {
  const el = document.getElementById(id);
  if (!el) return;
  el.textContent = text;
  el.className = 'sm show ' + (ok ? 'ok' : 'err');
  setTimeout(() => el.className = 'sm', 4000);
}

function showResult(id, ok, text) {
  const el = document.getElementById(id);
  if (!el) return;
  el.textContent = text;
  el.className = 'ac-result show ' + (ok ? 'ok' : 'err');
}

// ── Save config section ────────────────────────────────────────
const sectionFields = {
  welcome:     ['welcomeEnabled','welcomeChannel','welcomeMessage','welcomePing','welcomeDm','welcomeDmMessage','welcomeBanner'],
  farewell:    ['farewellEnabled','farewellChannel','farewellMessage'],
  logging:     ['logsEnabled','logsChannel','modLogsChannel','msgLogsChannel','joinLogsChannel'],
  automod:     ['autoMod','antiSpam','antiLinks','antiInvites','antiCaps','badWords'],
  antiraid:    ['antiRaidEnabled','antiRaidThreshold','antiRaidWindow','antiRaidAction'],
  antinuke:    ['antiNukeEnabled','antiNukeThreshold','antiNukeAction'],
  tickets:     ['ticketsEnabled','ticketSupportRole','ticketLogChannel','ticketMaxOpen'],
  leveling:    ['levelingEnabled','xpPerMsg','levelCooldown','levelUpChannel','levelAnnounce'],
  roles:       ['mutedRole','autoRole'],
  suggestions: ['suggestChannel'],
};

async function save(section) {
  const fields = sectionFields[section] || [];
  const body = { _section: section };
  fields.forEach(id => {
    const el = document.getElementById(id);
    if (!el) return;
    body[id] = el.type === 'checkbox' ? String(el.checked) : el.value;
  });

  const btns = document.querySelectorAll(`#panel-${section} .btn-gold`);
  btns.forEach(b => { b.disabled = true; b.textContent = '⏳ Saving...'; });

  try {
    const r = await fetch(`/dashboard/${GUILD}/save`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    const d = await r.json();
    showMsg(`sm-${section}`, d.success, d.success ? `✅ Saved ${d.saved} settings!` : `❌ ${d.error}`);
  } catch (e) {
    showMsg(`sm-${section}`, false, '❌ Network error');
  }

  btns.forEach(b => { b.disabled = false; b.textContent = '💾 Save ' + section.charAt(0).toUpperCase() + section.slice(1); });
}

// ── Live actions ───────────────────────────────────────────────
async function action(type) {
  try {
    const r = await fetch(`/dashboard/${GUILD}/action/${type}`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}' });
    const d = await r.json();
    alert(d.success ? d.message : '❌ ' + d.error);
  } catch { alert('❌ Network error'); }
}

async function modAction(type, body, resultId) {
  try {
    const r = await fetch(`/dashboard/${GUILD}/action/${type}`, {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
    });
    const d = await r.json();
    showResult(resultId, d.success, d.success ? d.message : '❌ ' + d.error);
  } catch { showResult(resultId, false, '❌ Network error'); }
}

async function postPanel() {
  const channelId = val('panelChannel');
  if (!channelId) return showResult('panel-result', false, '❌ Select a channel first.');
  const r = await fetch(`/dashboard/${GUILD}/action/ticket-panel`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ channelId }) });
  const d = await r.json();
  showResult('panel-result', d.success, d.success ? d.message : '❌ ' + d.error);
}

async function sendAnnounce() {
  const body = { channelId: val('annChannel'), title: val('annTitle'), message: val('annMessage'), color: val('annColor') };
  if (!body.channelId || !body.title || !body.message) return showResult('ann-result', false, '❌ Fill in channel, title, and message.');
  const r = await fetch(`/dashboard/${GUILD}/action/announce`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
  const d = await r.json();
  showResult('ann-result', d.success, d.success ? d.message : '❌ ' + d.error);
}

// ── Data loaders ───────────────────────────────────────────────
async function loadTournaments() {
  const wrap = document.getElementById('tourney-wrap');
  const data = await fetch(`/api/guild/${GUILD}/tournaments`).then(r=>r.json());
  if (!data.length) { wrap.innerHTML = '<div class="empty"><div class="ei">🏆</div><p>No tournaments yet.</p></div>'; return; }
  const st = s => `<span class="badge ${s==='open'?'b-open':s==='ongoing'?'b-ongoing':'b-closed'}">${s.toUpperCase()}</span>`;
  wrap.innerHTML = `<table class="tbl"><thead><tr><th>Name</th><th>Game</th><th>Teams</th><th>Format</th><th>Prize</th><th>Status</th></tr></thead><tbody>${data.map(t=>`<tr><td style="color:var(--text);font-weight:500">${t.name}</td><td>${t.game}</td><td>${t.teams?.length||0}/${t.maxTeams}</td><td>${(t.format||'').replace('_',' ')}</td><td>${t.prize||'—'}</td><td>${st(t.status)}</td></tr>`).join('')}</tbody></table>`;
}

async function loadTickets() {
  const wrap = document.getElementById('ticket-wrap');
  const data = await fetch(`/api/guild/${GUILD}/tickets`).then(r=>r.json());
  if (!data.length) { wrap.innerHTML = '<div class="empty"><div class="ei">🎫</div><p>No tickets found.</p></div>'; return; }
  const st = s => `<span class="badge ${s==='open'||s==='claimed'?'b-open':'b-closed'}">${s.toUpperCase()}</span>`;
  const pri = p => ({ low:'🟢', normal:'🟡', high:'🔴', critical:'🚨' }[p]||'🟡');
  wrap.innerHTML = `<table class="tbl"><thead><tr><th>ID</th><th>Type</th><th>Subject</th><th>Priority</th><th>Status</th><th>Action</th></tr></thead><tbody>${data.map(t=>`<tr><td style="font-family:monospace;color:var(--gold);font-size:.78rem">${t.ticketId}</td><td>${t.type}</td><td style="color:var(--text)">${(t.subject||'').slice(0,40)}</td><td>${pri(t.priority)} ${t.priority||'normal'}</td><td>${st(t.status)}</td><td>${t.status!=='closed'?`<button class="btn btn-danger btn-sm" onclick="closeTicket('${t.ticketId}',this)">Close</button>`:'—'}</td></tr>`).join('')}</tbody></table>`;
}

async function closeTicket(ticketId, btn) {
  btn.disabled = true; btn.textContent = '...';
  const r = await fetch(`/dashboard/${GUILD}/action/close-ticket`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ ticketId }) });
  const d = await r.json();
  if (d.success) { btn.closest('tr').querySelector('td:nth-child(5)').innerHTML = '<span class="badge b-closed">CLOSED</span>'; btn.remove(); }
  else { btn.disabled = false; btn.textContent = 'Close'; alert('❌ ' + d.error); }
}

async function loadModlogs() {
  const wrap = document.getElementById('modlog-wrap');
  const data = await fetch(`/api/guild/${GUILD}/modlogs`).then(r=>r.json());
  if (!data.length) { wrap.innerHTML = '<div class="empty"><div class="ei">⚖️</div><p>No mod cases yet.</p></div>'; return; }
  const colors = { ban:'b-closed', kick:'b-ongoing', mute:'b-ongoing', warn:'', unban:'b-open', unmute:'b-open' };
  wrap.innerHTML = `<table class="tbl"><thead><tr><th>#</th><th>Type</th><th>User</th><th>Moderator</th><th>Reason</th><th>When</th></tr></thead><tbody>${data.map(c=>`<tr><td style="color:var(--gold);font-weight:700">${c.caseId}</td><td><span class="badge ${colors[c.type]||''}">${(c.type||'').toUpperCase()}</span></td><td style="font-size:.8rem">${c.userTag||c.userId}</td><td style="font-size:.8rem">${c.modTag||c.modId}</td><td style="color:var(--text2);font-size:.82rem">${(c.reason||'').slice(0,50)}</td><td style="font-size:.78rem;color:var(--text3)">${c.timestamp?new Date(c.timestamp).toLocaleDateString():''}</td></tr>`).join('')}</tbody></table>`;
}

async function loadLeaderboard() {
  const wrap = document.getElementById('lb-wrap');
  const data = await fetch(`/api/guild/${GUILD}/leaderboard`).then(r=>r.json());
  if (!data.length) { wrap.innerHTML = '<div class="empty"><div class="ei">🏅</div><p>No data yet. Users gain points through tournaments and XP.</p></div>'; return; }
  const medals = ['🥇','🥈','🥉'];
  wrap.innerHTML = `<table class="tbl"><thead><tr><th>Rank</th><th>User</th><th>Points</th><th>Level</th><th>Wins</th><th>Coins</th></tr></thead><tbody>${data.map((u,i)=>`<tr><td>${medals[i]||`<strong style="color:var(--text3)">#${i+1}</strong>`}</td><td style="color:var(--text);font-weight:500">${u.username}</td><td style="color:var(--gold);font-weight:700">${u.points}</td><td>${u.level}</td><td>${u.wins}</td><td>🪙 ${u.coins}</td></tr>`).join('')}</tbody></table>`;
}

async function loadMembers() {
  const wrap = document.getElementById('members-wrap');
  const data = await fetch(`/api/guild/${GUILD}/members`).then(r=>r.json());
  if (!data.length) { wrap.innerHTML = '<div class="empty"><div class="ei">👥</div><p>Could not load members.</p></div>'; return; }
  wrap.innerHTML = `<table class="tbl"><thead><tr><th>Member</th><th>Roles</th><th>Joined</th><th>Type</th></tr></thead><tbody>${data.map(m=>`<tr><td><div style="display:flex;align-items:center;gap:9px"><img src="${m.avatar}" style="width:28px;height:28px;border-radius:50%"><span style="color:var(--text)">${m.username}</span></div></td><td style="font-size:.78rem;color:var(--text3)">${m.roles.join(', ')||'—'}</td><td style="font-size:.78rem;color:var(--text3)">${m.joinedAt?new Date(m.joinedAt).toLocaleDateString():''}</td><td>${m.bot?'<span class="badge b-bot">BOT</span>':'👤'}</td></tr>`).join('')}</tbody></table>`;
}

// ── Live ping update ───────────────────────────────────────────
async function updatePing() {
  try {
    const d = await fetch(`/api/guild/${GUILD}/stats`).then(r=>r.json());
    const el = document.getElementById('bot-ping');
    if (el && d.ping !== undefined) {
      const cls = d.ping < 100 ? 'ping-good' : d.ping < 200 ? 'ping-ok' : 'ping-bad';
      el.innerHTML = `<span class="ping-dot ${cls}"></span>${d.ping}ms`;
    }
    const tEl = document.getElementById('stat-tickets');
    if (tEl && d.tickets !== undefined) tEl.textContent = d.tickets;
  } catch {}
}
updatePing();
setInterval(updatePing, 15000);
</script>
